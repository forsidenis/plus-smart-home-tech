KAFKA_BOOTSTRAP_SERVERS=localhost:9092
KAFKA_CONSUMER_AUTO_OFFSET_RESET=earliest
KAFKA_CONSUMER_AUTO_OFFSET_LAST=latest

KAFKA_PRODUCER_KEY_SERIALIZER=org.apache.kafka.common.serialization.StringSerializer
KAFKA_PRODUCER_VALUE_SERIALIZER=serializer.AvroSerializer

KAFKA_CONSUMER_KEY_DESERIALIZER=org.apache.kafka.common.serialization.StringDeserializer
KAFKA_CONSUMER_VALUE_DESERIALIZER_SENSOR=deserializer.SensorEventDeserializer

KAFKA_CONSUMER_GROUP_ID_AGGREGATOR=sensor-aggregator-group

SPRING_DATASOURCE_URL_ANALYZER=jdbc:postgresql://localhost:5432/analyzer
 POSTGRES_DB_ANALYZER=analyzer
 POSTGRES_USER_ANALYZER=analyzer
 POSTGRES_PASSWORD_ANALYZER=analyzer